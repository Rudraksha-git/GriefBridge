datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String     @id // Clerk user ID
  email        String     @unique
  firstName    String?
  lastName     String?
  deceasedName String?
  relationship String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  tasks        Task[]
  documents    Document[]
  memories     Memory[]
}

model Task {
  id          String     @id @default(uuid())
  title       String
  description String?
  status      String     @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED
  priority    String     @default("MEDIUM") // HIGH, MEDIUM, LOW
  category    String?    // legal, financial, personal, digital
  dueDate     DateTime?
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents   Document[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Document {
  id          String   @id @default(uuid())
  title       String
  type        String   // bank_closure, insurance_claim, legal_heir, epf, aadhaar, etc.
  status      String   @default("DRAFT") // DRAFT, GENERATED, SIGNED, SUBMITTED
  content     Json?    // Stores the filled form fields (JSON)
  fileUrl     String?  // PDF file path/URL
  taskId      String?
  task        Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Memory {
  id         String   @id @default(uuid())
  type       String   // voice, chat, photo, text
  content    String   // Text transcript or note
  embedding  Float[]  // Vector embedding of the content
  metadata   Json?    // EXIF, speaker tags, timestamps, etc.
  fileUrl    String?  // S3 or local url
  sourceFile String?
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
